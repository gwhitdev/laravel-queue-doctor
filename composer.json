{
    "name": "gwhitdev/laravel-queue-doctor",
    "description": "Diagnose Laravel queue health and web-tier store reachability: catch worker/connection mismatches, stalled backlogs, and the cache/session Redis outages that 500 every request.",
    "keywords": ["laravel", "queue", "redis", "diagnostics", "health-check", "ops", "horizon", "artisan"],
    "license": "MIT",
    "authors": [
        {
            "name": "Gareth Whitleychard",
            "email": "garethwhitleychard@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "QueueDoctor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "QueueDoctor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "QueueDoctor\\QueueDoctorServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
